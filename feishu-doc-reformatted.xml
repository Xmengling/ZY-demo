<th background-color="light-gray">加权总量</th>
<th background-color="light-gray">计算式</th>
</tr>
</thead>
<tbody>
<tr><td>小柴胡汤</td><td>28</td><td>2</td><td>56</td><td>28 × 2</td></tr>
<tr><td>五苓散</td><td>16</td><td>5</td><td>80</td><td>16 × 5</td></tr>
<tr><td>吴茱萸汤</td><td>20</td><td>1</td><td>20</td><td>20 × 1</td></tr>
